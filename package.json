{
  "name": "stitcher",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspace=packages/types --workspace=apps/api --workspace=apps/web",
    "build:types": "npm run build --workspace=packages/types",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:dev:clean": "docker compose -f docker/docker-compose.dev.yml down -v",
    "docker:prod": "docker compose -f docker/docker-compose.yml up --build -d",
    "docker:prod:down": "docker compose -f docker/docker-compose.yml down"
  }
}