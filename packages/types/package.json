{
  "name": "@stitcher/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for Stitcher monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
